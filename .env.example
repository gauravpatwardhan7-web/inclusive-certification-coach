# Copy this file to ".env" and fill in your real values.
# ".env" is gitignored and must NEVER be committed.

# Azure AI Foundry project endpoint (from Foundry > project Overview > Endpoints)
AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Azure OpenAI-style endpoint (from Foundry > project Overview > Azure OpenAI endpoint)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1

# Your API key (Foundry > project Overview > API key). Secret — keep out of git.
AZURE_AI_API_KEY=your-api-key-here

# Deployed model names (Foundry > Build > Deployments)
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_DEPLOYMENT_REASONING=o4-mini

# API version for the Azure OpenAI endpoint
AZURE_OPENAI_API_VERSION=2024-10-21

# Foundry IQ / Azure AI Search (grounded retrieval)
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_INDEX=cert-guides-index
